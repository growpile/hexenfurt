- !<ScriptComponent/ba2bc9c2-8841-470a-8021-95b94b8ed71a>
  PrefabRemaps:
    []
  Name: ArchiveGallery
  Enabled: true
  ScriptAsset: !<reference> dee3ed28-bcd3-420f-b90f-ca2488298728
  ScriptInputsDefault:
    descriptionFadeDuration: true
    descriptionSwapDelay: true
    rotationCycleDuration: true
    objectScaleDuration: true
    entrySlideUnits: true
    entrySlideDuration: true
  ScriptTypesDefault:
    {}
  ScriptInputs:
    "":
      entries:
        - objectId: door
          objectPrefab: !<reference.ObjectPrefab> 8315e17c-0445-4b89-9ba0-508d94262289
          description: |-
            The Escape Door. I need to go now.
            I must tell what I know.
        - objectId: table
          objectPrefab: !<reference.ObjectPrefab> be48089e-3679-439b-9a13-26e3ee771574
          description: A small table with a drawer. The perfect place to hide something.
        - objectId: vase3
          objectPrefab: !<reference.ObjectPrefab> 8aa72a7e-7f88-4db5-af2e-fda8ebf61b77
          description: An emerald vase. A faint rattle echoes from inside when I move it.
        - objectId: statue
          objectPrefab: !<reference.ObjectPrefab> b8f2508b-4232-457a-995e-20457a51123d
          description: A well-preserved marble bust. Perhaps his identity matters.
        - objectId: bookshelf
          objectPrefab: !<reference.ObjectPrefab> 0e75f9f6-9ff0-4836-92a3-7a69c03beecd
          description: "A towering bookshelf with numbered volumes. Is there a sequence?"
        - objectId: painting
          objectPrefab: !<reference.ObjectPrefab> 831389f0-af48-4661-809d-eea8a964982a
          description: A beautiful painting. Appearances can be deceiving in this mansion.
        - objectId: gramophone
          objectPrefab: !<reference.ObjectPrefab> 062b85bb-3800-47e2-9f59-4dad259a2e7b
          description: An old gramophone. Perhaps it still has a story left to tell.
        - objectId: magicBall
          objectPrefab: !<reference.ObjectPrefab> c8003620-a993-454f-bc12-168f17078d15
          description: A mysterious crystal ball. Its cloudy depths seem almost alive.
        - objectId: vase2
          objectPrefab: !<reference.ObjectPrefab> bb2ebec5-15ce-49e9-bbeb-17b59e076e4a
          description: "A golden vase. The weight feels uneven, as if somethings hides in it."
        - objectId: keySafe
          objectPrefab: !<reference.ObjectPrefab> 60e80330-927a-4ea0-853c-4f1f67250a21
          description: "A key safe made of silver. Where could the key be?"
        - objectId: chandelier
          objectPrefab: !<reference.ObjectPrefab> 817316fe-1c0d-49d2-b664-8988b4d734a9
          description: A grand chandelier. The flickering light casts shifting shadows.
        - objectId: chest
          objectPrefab: !<reference.ObjectPrefab> b8e84347-c926-47a8-9abf-0b6efc6bafb5
          description: A sturdy chest with bronze trims. Whatever lies inside could be useful.
        - objectId: clock
          objectPrefab: !<reference.ObjectPrefab> 6d04af6b-cafb-457a-aa56-3510d0e6f99b
          description: A magnificent clock. Time itself may be part of the puzzle.
        - objectId: vase4
          objectPrefab: !<reference.ObjectPrefab> 3fbb782b-15c9-454a-93d0-37ccf1ffad63
          description: A golden vase. Something shifts inside whenever I pick it up.
        - objectId: fan
          objectPrefab: !<reference.ObjectPrefab> ce3d426b-635d-4980-a2e3-a6cd7b271303
          description: A wooden fan. Something about it feels slightly out of place.
        - objectId: codeSafe
          objectPrefab: !<reference.ObjectPrefab> 6a0c27d4-7dfb-43ca-9d83-bdccbbfaa56c
          description: A locked code safe. I need the correct combination to uncover its contents.
        - objectId: vase1
          objectPrefab: !<reference.ObjectPrefab> 7c6c2fda-fc3f-416e-94ab-a2bd9ab4545a
          description: An emerald vase. Its contents seem more interesting than its exterior.
      objectDisplayRoot: !<reference.SceneObject> b46239b9-99cf-41ca-85ac-2c961ad82424
      objectDescription: !<reference.Text> 816b187e-38e2-496f-b5e3-cb6b21921e40
      notSeenIcon: !<reference.SceneObject> c039e6d3-65fd-4d5b-a152-eecf967084fc
